VLADCHER_BASE_URL=https://example.vladcher.local
VOVAN_WORKER_TOKEN=replace-me
VOVAN_MODE=local
VOVAN_DATA_DIR=./data
VOVAN_LOG_DIR=./logs
VOVAN_REPORT_DIR=./reports
VOVAN_ALLOWED_EXTENSIONS=.pdf,.png,.jpg,.jpeg,.tiff,.txt
VOVAN_MAX_FILE_SIZE_MB=50
VOVAN_DRY_RUN=true
VOVAN_REQUEST_TIMEOUT_SECONDS=30
VOVAN_WORKER_SLEEP_SECONDS=5
VOVAN_DOWNLOAD_DIR=./data/downloads
